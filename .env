# Entra ID / MSAL (Next.js public vars)
NEXT_PUBLIC_AZURE_CLIENT_ID=b2ca918f-3d24-4838-8700-6830d2e28e17
NEXT_PUBLIC_AAD_TENANT_ID=3427e2ad-ba6d-4100-aec4-f3f18e4b32d1
# Optional explicit authority; if omitted authority is built from tenant id.
# NEXT_PUBLIC_AZURE_AUTHORITY=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000
# NEXT_PUBLIC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# OAuth scopes requested at sign-in (space/comma separated)
NEXT_PUBLIC_LOGIN_SCOPES=openid profile email User.Read Sites.Read.All

# SharePoint site used for connection probe
NEXT_PUBLIC_SHAREPOINT_SITE_URL=https://easeint1.sharepoint.com/sites/Letters

# Optional compatibility keys (LN-style); Next config maps these as fallback.
# REACT_APP_AZURE_CLIENT_ID=
# REACT_APP_AAD_TENANT_ID=
# REACT_APP_AZURE_AUTHORITY=
# REACT_APP_REDIRECT_URI=
# REACT_APP_POST_LOGOUT_REDIRECT_URI=
# REACT_APP_LOGIN_SCOPES=
# REACT_APP_SHAREPOINT_SITE_URL=
